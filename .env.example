# Chat LLM
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# Embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=local-hash-768
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
LOCAL_EMBEDDING_DIMENSIONS=768

# Redis
REDIS_URL=redis://localhost:6379/0
SEARCH_CACHE_TTL_SECONDS=3600

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=paper_agent
POSTGRES_PASSWORD=paper_agent
POSTGRES_DBNAME=paper_agent
POSTGRES_SSLMODE=disable
POSTGRES_POOL_MIN_CONNECTIONS=1
POSTGRES_POOL_MAX_CONNECTIONS=4

# Chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Upload
UPLOAD_DIR=./uploads
MAX_ANALYSIS_PAPERS=5

# Token budget
SESSION_TOKEN_BUDGET=50000
TOKEN_COMPRESS_THRESHOLD=0.8
TOKEN_RESERVED_OUTPUT_TOKENS=2000
TOKEN_KEEP_RECENT_TURNS=3
